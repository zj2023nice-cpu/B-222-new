.appointment-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  margin-bottom: 24rpx;
}

.appointment-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.03);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.expert-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.expert-text {
  display: flex;
  flex-direction: column;
}

.expert-expertise {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.expert-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.student-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  line-height: 48rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}

.value.danger {
  color: #e34d59;
}

.value.waitlist-queue {
  color: #ed7b2f;
  font-weight: 600;
}

.cancelled-info {
  margin-top: 8rpx;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  gap: 48rpx;
  width: 100%;
}

.footer-btn {
  --td-button-medium-margin: 0;
  --td-button-small-margin: 0;
  --td-button-extra-small-margin: 0;
  margin: 0;
}

/* 弹窗内容样式 */
.contact-dialog-content,
.eval-dialog-content {
  padding: 32rpx 0 0;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.contact-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 4rpx;
  margin-bottom: 16rpx;
}

.contact-item .label,
.form-label {
  font-size: 26rpx;
  color: #999;
}

.contact-item .value {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.contact-item .phone-number {
  color: #0052d9;
}

.contact-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background-color: #f3f6fb;
  border-radius: 12rpx;
  color: #0052d9;
  font-size: 24rpx;
  margin-top: 16rpx;
}

.eval-textarea {
  min-height: 240rpx;
  --td-textarea-background-color: #f9f9f9;
}
