.timeline-container {
  margin: 32rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.timeline-header {
  margin-bottom: 40rpx;
}

.timeline-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.timeline-subtitle {
  font-size: 24rpx;
  color: #999;
}

.timeline-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.timeline-empty {
  padding: 80rpx 0;
}

.timeline-group {
  margin-bottom: 24rpx;
}

.timeline-group:last-child {
  margin-bottom: 0;
}

.timeline-date-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.date-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(43deg, #8ec5fc 0%, #e0c3fc 100%);
  margin-right: 16rpx;
}

.date-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.timeline-item {
  display: flex;
  position: relative;
  min-height: 140rpx;
}

.timeline-node-wrap {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 48rpx;
  flex-shrink: 0;
}

.timeline-node {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  margin-top: 8rpx;
  z-index: 2;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx #fff;
}

.node-mood {
  background: #e37318;
}

.node-assessment {
  background: #0052d9;
}

.node-appointment {
  background: #00a870;
}

.timeline-line {
  flex: 1;
  width: 4rpx;
  background: linear-gradient(
    to bottom,
    rgba(142, 197, 252, 0.6) 0%,
    rgba(224, 195, 252, 0.3) 100%
  );
  margin-top: 4rpx;
}

.timeline-line-last {
  background: transparent;
}

.timeline-content {
  flex: 1;
  margin-left: 16rpx;
  padding-bottom: 32rpx;
  padding-right: 8rpx;
}

.timeline-item-last .timeline-content {
  padding-bottom: 0;
}

.timeline-content-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.timeline-time {
  font-size: 22rpx;
  color: #bbb;
}

.timeline-desc {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.timeline-subdesc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
  word-break: break-all;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
