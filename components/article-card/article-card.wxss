.article-card {
  display: flex;
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx;
  gap: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s ease;
  margin-bottom: 24rpx;
}

.article-card:active {
  background-color: #f9f9f9;
}

.article-cover-container {
  position: relative;
  width: 220rpx;
  height: 160rpx;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 12rpx;
}

.image-deleted {
  filter: grayscale(100%);
  opacity: 0.6;
}

.deleted-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.deleted-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.text-deleted {
  color: #999;
  text-decoration: line-through;
}

.article-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}

.article-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center; /* 改为居中对齐，实现水平对齐效果 */
  gap: 12rpx;
  min-height: 44rpx; /* 保证即便标题只有一行时也能与图标完美居中 */
}

.article-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  overflow: hidden;
}

.article-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.article-views {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx; /* 统一为 22rpx，与之前 index 页面一致 */
  color: #999;
}

.article-views .view-icon {
  margin-right: 0;
}

.collect-icon-area {
  padding: 8rpx;
  /* 增加一点点击区域方便操作 */
  margin-right: -8rpx;
}
