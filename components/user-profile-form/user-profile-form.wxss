.profile-form-container {
  background-color: #f8fafc;
  position: relative;
}

.header-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 360rpx;
  background: linear-gradient(135deg, #0052d9 0%, #003cab 100%);
  border-radius: 0 0 80rpx 80rpx;
  z-index: 0;
}

.profile-card {
  position: relative;
  height: 100%;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar-wrapper {
  position: relative;
  padding: 8rpx;
  margin-top: 40rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.avatar-image {
  border: 4rpx solid #fff;
  border-radius: 50%;
  overflow: hidden;
}

.camera-icon-wrap {
  position: absolute;
  right: 6rpx;
  bottom: 6rpx;
  width: 56rpx;
  height: 56rpx;
  background: #0052d9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.avatar-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 20rpx;
}

.custom-cell-group {
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.form-section {
  width: 100%;
  margin-top: 40rpx;
  border-radius: 20rpx;
}

.form-label {
  --td-input-label-text-font: #334155;
  --td-input-label-text-color: #334155;
  --td-cell-title-color: #334155;
  font-size: 32rpx;
  font-weight: 600;
  min-width: 160rpx;
  flex-shrink: 0;
}

.note-active {
  color: #1e293b;
  font-size: 32rpx;
  max-width: 480rpx;
  text-align: right;
  white-space: normal;
  word-break: break-all;
  line-height: 1.4;
}

.note-placeholder {
  color: #94a3b8;
  font-size: 32rpx;
}

.textarea-cell {
  background: #fff;
  padding: 32rpx;
  border-top: 1rpx solid #f1f5f9;
}

.textarea-label {
  font-size: 32rpx;
  color: #334155;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.custom-textarea {
  --td-textarea-background-color: #f1f5f9;
  min-height: 320rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
}

.action-section {
  padding: 40rpx 32rpx;
}

.submit-btn {
  height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 24rpx rgba(0, 82, 217, 0.2);
}

.custom-input {
  --td-input-placeholder-font-size: 32rpx;
  --td-input-font-size: 32rpx;
}

.custom-input .suffix-icon {
  padding-left: 0;
}

.multi-select-container {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.popup-cancel {
  font-size: 28rpx;
  color: #94a3b8;
}

.popup-confirm {
  font-size: 28rpx;
  color: #0052d9;
  font-weight: 600;
}

.popup-content {
  max-height: 600rpx;
}
