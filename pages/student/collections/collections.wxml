<view class="container">
  <t-navbar title="我的收藏" left-arrow placeholder />
  <t-sticky offset-top="{{ navbarHeight }}">
    <view class="search-wrap">
      <t-search
        placeholder="搜索收藏的文章"
        bind:submit="onSearch"
        bind:clear="onSearchClear"
        value="{{ keyword }}"
        shape="round"
        style="flex: 1"
      />
    </view>
  </t-sticky>

  <!-- 加载中：仅显示骨架屏 -->
  <view wx:if="{{ isLoading }}" class="skeleton-list">
    <view wx:for="{{ 3 }}" wx:key="index" class="skeleton-item">
      <t-skeleton rowCol="{{ imageSkeleton }}" animation="flashing" />
      <view class="skeleton-content">
        <t-skeleton rowCol="{{ infoSkeleton }}" animation="flashing" />
      </view>
    </view>
  </view>

  <!-- 加载完成：显示结果或空状态 -->
  <list-view
    wx:else
    isRefreshing="{{ isRefreshing }}"
    isEmpty="{{ collections.length === 0 }}"
    showFooter="{{ collections.length > 0 }}"
    emptyText="{{ keyword ? '未搜索到相关文章' : '暂无收藏的文章' }}"
    bind:refresh="onRefresh"
  >
    <view class="collection-list">
      <article-card
        wx:for="{{ collections }}"
        wx:key="_id"
        article="{{ item }}"
        showCollectMode="{{ true }}"
        bind:click="navToDetail"
        bind:uncollect="onUncollect"
      />
    </view>
  </list-view>

  <t-dialog id="t-dialog" />
  <t-toast id="t-toast" />
</view>
