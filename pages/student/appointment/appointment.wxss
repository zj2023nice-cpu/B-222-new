.container {
  min-height: 100vh;
  background-color: #f8f8f8;
  display: flex;
  flex-direction: column;
}

.search-wrap {
  background-color: #fff;
  padding: 24rpx 32rpx;
}

.pull-down-refresh {
  flex: 1;
  display: block;
  height: 0; /* 配合 flex: 1 确保高度受容器控制 */
}

.consultant-list {
  padding: 32rpx;
}

.list-footer {
  text-align: center;
  padding: 20rpx 0;
  color: #bbb;
  font-size: 24rpx;
}

.consultant-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: flex-start;
  cursor: pointer;
  transition: background 0.15s;
}

.consultant-card:active {
  background: #f5f5f5;
}

.avatar {
  flex-shrink: 0;
  border-radius: 50%;
}

.content {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.name-left {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
  white-space: nowrap;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-right: 12rpx;
  flex-shrink: 1;
  overflow: hidden;
  text-overflow: ellipsis;
}

.book-btn-mini {
  --td-button-extra-small-height: 48rpx;
  --td-button-font-size: 22rpx;
  width: 120rpx;
  padding: 0;
  margin: 0;
}

.btn-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.waitlist-tag {
  flex-shrink: 0;
}

.expert-tag-icon {
  margin-right: 4rpx;
  display: flex;
  align-items: center;
}

.rating {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.score {
  font-size: 24rpx;
  color: #ed7b2f;
  margin-left: 12rpx;
  font-weight: bold;
}

.expert {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.intro {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-clamp: 2;
}

/* 弹窗样式 */
.popup-content {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.popup-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

/* 日期选择器 */
.date-selector {
  margin-bottom: 40rpx;
}

.date-scroll {
  white-space: nowrap;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 140rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  margin-right: 20rpx;
  transition: all 0.2s;
}

.date-item.active {
  background: #0052d9;
  color: #fff;
}

.date-item.disabled {
  opacity: 0.5;
  background: #ddd;
  color: #999;
  pointer-events: none;
}

.date-item.waitlist {
  opacity: 1;
  background: #fff7e6;
  color: #ed7b2f;
  pointer-events: auto;
  border: 2rpx solid #ffe4b5;
}

.date-item.notified {
  opacity: 1;
  background: #e8f5e9;
  color: #43a047;
  pointer-events: auto;
  border: 2rpx solid #a5d6a7;
}

.date-item .week {
  font-size: 22rpx;
  margin-bottom: 8rpx;
  opacity: 0.8;
}

.date-item .day {
  font-size: 36rpx;
  font-weight: bold;
}

.date-badge {
  font-size: 18rpx;
  margin-top: 4rpx;
  font-weight: normal;
}

.full-badge {
  color: #999;
}

.notified-badge {
  color: #43a047;
  font-weight: bold;
}

/* 时间段选择器 */
.time-section {
  margin-bottom: 60rpx;
}

.time-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.time-item {
  width: 48%;
  height: 88rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  box-sizing: border-box;
  transition: all 0.2s;
}

.time-item.active {
  background: #e1f0ff;
  border: 2rpx solid #0052d9;
  color: #0052d9;
}

.time-item.disabled {
  opacity: 0.4;
  background: #eee;
}

.time-item .time {
  font-size: 24rpx;
  font-weight: bold;
}

.time-item .status {
  font-size: 20rpx;
}

.popup-footer {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 确认弹窗内文字 */
.confirm-content {
  text-align: left;
  padding: 32rpx 0;
}

.confirm-info-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.confirm-info-item .label {
  color: #999;
  width: 140rpx;
  flex-shrink: 0;
}

.confirm-info-item .value {
  color: #333;
}

.confirm-info-item .bold {
  font-weight: bold;
}

.confirm-info-item.space-between {
  justify-content: space-between;
  width: 100%;
}

.item-sub {
  display: flex;
  align-items: center;
}

.label-tiny {
  color: #999;
  font-size: 26rpx;
  margin-right: 8rpx;
}

.confirm-tip {
  font-size: 24rpx;
  color: #ed7b2f;
  margin-top: 32rpx;
  background: #fff8f5;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
}

.confirm-tip.danger {
  color: #d20505;
  background: #fff0f0;
}

/* 骨架屏 */
.skeleton-container {
  padding: 32rpx;
}

.skeleton-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 30rpx;
  display: flex;
}

.empty-state {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
}

.custom-toast {
  text-align: center;
}

.detail-panel {
  width: 75vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #fff;
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.detail-header-info {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.detail-header-text {
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.detail-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-title {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.detail-body {
  flex: 1;
  height: 0;
  padding: 24rpx 32rpx;
}

.detail-section {
  margin-bottom: 36rpx;
}

.detail-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  position: relative;
  padding-left: 16rpx;
}

.detail-section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 4rpx;
  width: 6rpx;
  height: 24rpx;
  background: #0052d9;
  border-radius: 3rpx;
}

.detail-expertise {
  font-size: 26rpx;
  color: #444;
  line-height: 1.6;
  background: #f5f7fa;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
}

.detail-intro {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.detail-dates {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-date-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.detail-date-item.available {
  background: #f0f7ff;
}

.detail-date-item.full {
  background: #f5f5f5;
}

.detail-date-str {
  color: #333;
  font-weight: 500;
}

.detail-date-status {
  color: #999;
  font-size: 24rpx;
}

.detail-date-status.available {
  color: #0052d9;
  font-weight: 500;
}

.detail-full-notice {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #fff8f5;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #ed7b2f;
  margin-bottom: 24rpx;
}
