.container {
  background-color: #f8f8f8;
  display: flex;
  flex-direction: column;
}

.header {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: #ffffff;
  padding: 24rpx 32rpx;
}

.search-box {
  flex: 1;
}

.h1 {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.article-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.article-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  overflow: hidden;
}

.article-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.views {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999;
}

/* 骨架屏列表 */
.skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding: 32rpx;
}

.skeleton-item {
  background: #fff;
  padding: 24rpx;
  border-radius: 24rpx;
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}

.skeleton-content {
  flex: 1;
}

/* 下拉刷新容器自适应 */
.pull-down-refresh {
  display: block;
  flex: 1;
  min-height: 80vh;
}

.article-list {
  display: flex;
  flex-direction: column;
  padding: 32rpx;
}

/* 底部提示 */
.footer-divider {
  padding: 40rpx 0;
}

/* 空状态居中 */
.empty-wrapper {
  padding: 100rpx 0;
  text-align: center;
}
