.container {
  min-height: 100vh;
  background-color: #f6f6f6;
}

.header-section {
  padding: 24rpx 32rpx;
  background-color: #fff;
}

.custom-search {
  padding: 0;
}

.records-list,
.skeleton-container {
  padding: 32rpx 32rpx 0;
}

.record-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
  transition: all 0.3s;
}

.card-hover {
  transform: scale(0.99);
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.01);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.student-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.student-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.assessment-content {
  margin-bottom: 24rpx;
}

.assessment-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.feedback-text {
  font-size: 26rpx;
  color: #666;
  background: #f9f9f9;
  padding: 16rpx;
  border-radius: 8rpx;
  margin-top: 12rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  line-clamp: 3;
  overflow: hidden;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 2rpx solid #f9f9f9;
  padding-top: 16rpx;
}

.date-text {
  font-size: 24rpx;
  color: #999;
}

/* Dialog Styles */
.detail-wrapper {
  width: 100%;
  margin-top: 36rpx;
}

.detail-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
  width: 100%;
}

.detail-title-col {
  flex: 1;
  margin-left: 20rpx;
  text-align: left;
  overflow: hidden;
}

.detail-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.detail-date {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.detail-score {
  font-size: 40rpx;
  font-weight: 700;
  flex-shrink: 0;
  margin-left: 16rpx;
  margin-right: 8rpx;
}

.detail-score.high {
  color: #00a870;
}

.detail-score.low {
  color: #ed7b2f;
}

.detail-section {
  text-align: left;
  margin-top: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.suggestion-scroll {
  max-height: 450rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.suggestion-text {
  padding: 24rpx;
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
  text-align: left;
  min-height: 160rpx;
}

.skeleton-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.skeleton-card .t-skeleton__row:first-child {
  justify-content: flex-start;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}

.empty-text {
  margin-top: 24rpx;
  font-size: 30rpx;
  color: #999;
}
