.container {
  min-height: 100vh;
  background-color: #f8f8f8;
}

/* Header & Sticky Tabs */
.header-section {
  background: #ffffff;
}

.search-wrap {
  padding: 16rpx 32rpx;
}

.tabs-container {
  --td-tab-item-active-color: #0052d9;
  --td-tab-track-color: #0052d9;
}

.skeleton-list,
.appointment-list {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.skeleton-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.skeleton-card .t-skeleton__row:first-child {
  justify-content: flex-start;
}

.footer-btn {
  --td-button-medium-margin: 0;
  --td-button-small-margin: 0;
  --td-button-extra-small-margin: 0;
  margin: 0;
}

/* Eval Dialog */
.eval-dialog-content {
  padding: 32rpx 0 0;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.eval-textarea {
  height: 240rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}
