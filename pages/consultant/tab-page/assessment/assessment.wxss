.container {
  min-height: 100vh;
  background-color: #f6f6f6;
}

.search-container {
  padding: 24rpx 32rpx;
  background-color: #fff;
}
.header {
  padding: 32rpx;
  background-color: #fff;
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

.assess-list {
  padding: 32rpx 32rpx 0;
}

.assess-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
  transition: all 0.3s;
}

.card-hover {
  transform: scale(0.99);
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.01);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.assess-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.assess-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 24rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  line-clamp: 2;
  overflow: hidden;
}

.card-footer {
  display: flex;
  align-items: center;
}

.skeleton-list {
  padding: 32rpx 32rpx 0;
}

.skeleton-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.empty-state {
  padding-top: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-top: 24rpx;
  font-weight: 500;
}

.empty-sub {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
}

.fab-btn {
  bottom: calc(var(--tab-bar-height) + 64rpx) !important;
  right: 32rpx !important;
}
