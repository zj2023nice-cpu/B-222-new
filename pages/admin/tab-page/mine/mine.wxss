.dashboard-container {
  display: flex;
  flex-direction: column;
  background-color: #f6f6f6;
  padding-bottom: calc(var(--tab-bar-height, 180rpx) + 40rpx);
}

.user-header {
  position: relative;
  background-color: transparent;
  padding-bottom: 24rpx;
}

.header-bg {
  height: 220rpx;
  background: linear-gradient(43deg, #8ec5fc 0%, #e0c3fc 50%, #ffdee9 100%);
  border-radius: 0 0 100rpx 100rpx;
  position: relative;
  overflow: hidden;
}

.admin-bg {
  background: linear-gradient(135deg, #ff9d6c 0%, #bb4e75 100%);
}

.user-card-wrap {
  margin: -160rpx 32rpx 0;
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  position: relative;
}

.user-info-main {
  display: flex;
  align-items: center;
}

.user-text {
  flex: 1;
  margin-left: 32rpx;
}

.user-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.user-status {
  font-size: 24rpx;
  color: #999;
}

.menu-section {
  margin-top: 32rpx;
}

.logout-wrap {
  margin: 64rpx 32rpx 32rpx;
  border-radius: 48rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.logout-wrap:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.footer-tip {
  text-align: center;
  font-size: 22rpx;
  color: #ccc;
  padding: 40rpx 0;
}
