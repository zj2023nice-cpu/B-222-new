.container {
  background-color: #fff;
  min-height: 100vh;
  display: block;
}

.search-wrap {
  padding: 24rpx 32rpx;
  background-color: #fff;
  box-sizing: border-box;
}

.user-list {
  padding: 0;
}

/* Button styles for swipe-cell */
.btn-wrapper {
  height: 100%;
  display: flex;
}

.btn {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  width: 120rpx;
  height: 100%;
  color: #fff;
  font-size: 28rpx;
}

.btn-view {
  background-color: #0052d9;
}

.btn-edit {
  background-color: #ed7b2f;
}

.btn-delete {
  background-color: #e34d59;
}

.btn-disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Custom styles for t-cell slots */
.cell-avatar {
  display: block; /* ensure it behaves */
}

.cell-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.cell-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
  min-width: 0;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.user-role-tag {
  margin-left: 16rpx;
}

.expertise-row {
  display: flex;
  align-items: center;
  margin-top: 4rpx;
  color: #666;
  font-size: 24rpx;
  min-width: 0;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
}

.title-tag {
  margin-left: 16rpx;
}

.expertise-text {
  flex: 1;
  min-width: 0;
  width: 0; /* Force flex container to respect parent width */
}

.title-tag {
  margin-left: 16rpx;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  display: flex;
  justify-content: center;
}

/* TDesign Swipe Cell Customization */
.user-swipe-item {
  background-color: #fff;
  display: block;
}

/* Skeleton Styles */
.skeleton-item {
  background: #fff;
  padding: 32rpx;
  border-bottom: 2rpx solid #f6f6f6;
  display: flex;
  align-items: center;
}
.skeleton-content {
  flex: 1;
  margin-left: 24rpx;
}

.dialog-content {
  padding: 10rpx 0 32rpx;
}

.premium-detail-container {
  display: block;
  max-height: 50vh;
  background: #fff;
}

.premium-detail-container::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

.dialog-avatar {
  border: 6rpx solid #efefef;
}

.dialog-profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.header-info {
  text-align: center;
  margin-top: 24rpx;
}

.header-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.role-badge {
  display: inline-block;
}

.badge-row {
  display: flex;
  gap: 12rpx;
  justify-content: center;
  flex-wrap: wrap;
}

/* Stats Section */
.stats-grid {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.stat-card {
  flex: 1;
  padding: 32rpx 20rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
}

.stat-blue {
  background: #f0f5ff;
}

.stat-blue .stat-value {
  color: #0052d9;
}

.stat-orange {
  background: #fff7e8;
}

.stat-orange .stat-value {
  color: #ed7b2f;
}

.stat-value {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  font-weight: 500;
}

/* Details Section */
.details-list {
  background: #f8f8f8;
  border-radius: 24rpx;
  padding: 8rpx 24rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #efefef;
}

.detail-item:last-child {
  border-bottom: none;
}

.item-label {
  font-size: 26rpx;
  color: #888;
  margin: 0 20rpx;
  flex-shrink: 0;
}

.item-value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  text-align: right;
  font-weight: 600;
}

.detail-item-column {
  flex-direction: column;
  align-items: flex-start;
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  margin-bottom: 20rpx;
}

.item-header-left {
  display: flex;
  align-items: center;
}

.id-wrapper {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #eee;
}

.mini-id {
  flex: 1;
  font-family: "Courier New", Courier, monospace;
  font-size: 22rpx;
  color: #666;
  word-break: break-all;
  white-space: normal;
}

.intro-box {
  background: #fff;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #eee;
  max-height: 200rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.intro-box::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

.intro-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.copy-icon {
  padding: 8rpx;
  margin-right: -8rpx;
  opacity: 0.8;
  display: flex;
  align-items: center;
  justify-content: center;
}
