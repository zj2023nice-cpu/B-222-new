.container {
  min-height: 100vh;
  background-color: #f1f5f9;
}

/* Header & Search */
.header-section {
  background: #ffffff;
}

.search-wrap {
  padding: 16rpx 32rpx;
}

.tabs-container {
  --td-tab-item-active-color: #3b82f6;
  --td-tab-track-color: #3b82f6;
}

/* Stats Section */
.stats-grid {
  padding: 32rpx 32rpx 0;
  display: flex;
  gap: 24rpx;
}

.stats-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 16rpx rgba(148, 163, 184, 0.1);
  transition: transform 0.2s ease;
}

.stats-card:active {
  transform: scale(0.98);
}

.stats-card.total {
  flex: 1.2;
  background: linear-gradient(135deg, #ffffff 0%, #f0f7ff 100%);
  border-left: 8rpx solid #3b82f6;
}

.stats-mini-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stats-card.mini {
  padding: 20rpx 24rpx;
  flex: 1;
}

.stats-card.mini.pending {
  border-left: 6rpx solid #f59e0b;
}

.stats-card.mini.active {
  border-left: 6rpx solid #10b981;
}

.stats-info {
  display: flex;
  flex-direction: column;
}

.stats-label {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.stats-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
  font-family: "Outfit", sans-serif;
}

.stats-mini-group .stats-value {
  font-size: 32rpx;
}

.stats-icon-box {
  width: 80rpx;
  height: 80rpx;
  background: rgba(59, 130, 246, 0.1);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Skeleton Styles */
.skeleton-wrap {
  padding: 32rpx;
}

.skeleton-item {
  margin-bottom: 24rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
}

.skeleton-text {
  height: 32rpx;
  border-radius: 8rpx;
}

.skeleton-title {
  height: 48rpx;
  border-radius: 8rpx;
  width: 40%;
  margin-bottom: 32rpx;
}

/* Appointment List */
.appointment-list {
  padding: 32rpx 32rpx 0;
}

.appointment-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(148, 163, 184, 0.08);
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f1f5f9;
}

.footer-btn {
  --td-button-medium-margin: 0;
  --td-button-small-margin: 0;
  --td-button-extra-small-margin: 0;
  margin: 0;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f1f5f9;
  margin-bottom: 24rpx;
}

.id-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.time-text {
  font-size: 24rpx;
  color: #94a3b8;
}

/* User Grouping */
.user-info-group {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
  padding: 0 16rpx;
}

.user-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.user-item.right {
  justify-content: flex-end;
  text-align: right;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-role {
  font-size: 20rpx;
  color: #94a3b8;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 4rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.connect-line {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin: 0 24rpx;
}

.connect-line .dot {
  width: 6rpx;
  height: 6rpx;
  background: #cbd5e1;
  border-radius: 50%;
}

/* Appointment Details */
.appointment-info {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
}

.info-item .label {
  color: #64748b;
}

.info-item .value {
  color: #334155;
  font-weight: 500;
}

.info-item .value.highlight {
  color: #3b82f6;
  font-weight: 600;
}

/* Trend Chart Popup */
.trend-popup-content {
  background: #ffffff;
  width: 680rpx;
  border-radius: 32rpx;
  overflow: hidden;
  padding: 40rpx 32rpx;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.chart-container {
  width: 100%;
  height: 480rpx;
  background: #f8fafc;
  border-radius: 24rpx;
  padding: 20rpx 0;
}

.trend-canvas {
  width: 100%;
  height: 100%;
}

.popup-footer {
  margin-top: 32rpx;
  text-align: center;
}

.footer-hint {
  font-size: 22rpx;
  color: #94a3b8;
}
