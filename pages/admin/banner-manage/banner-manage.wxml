<view class="container">
  <t-navbar title="轮播图管理" left-arrow bind:go-back="onBack" placeholder />

  <view class="page-header">
    <t-search
      placeholder="搜索轮播标题"
      value="{{ keyword }}"
      bind:change="onSearch"
      bind:clear="onSearchClear"
      class="search-bar"
      shape="round"
    />
    <t-button theme="primary" icon="add" shape="circle" bindtap="handleAdd" />
  </view>

  <list-view
    isRefreshing="{{ isRefreshing }}"
    isEmpty="{{ banners.length === 0 && !isLoading }}"
    showFooter="{{ banners.length > 0 && !isLoading }}"
    footerText="已经到底了"
    emptyText="暂无轮播图，点击右上角添加"
    emptyIcon="image"
    minHeight="calc(100vh - 300rpx)"
    bind:refresh="onRefresh"
  >
    <view wx:if="{{ isLoading }}" class="skeleton-wrap">
      <view class="banner-item" wx:for="{{ 3 }}" wx:key="index">
        <t-skeleton theme="image" rows="{{ skeletonImage }}" loading />
        <view class="banner-info">
          <t-skeleton theme="text" rows="{{ skeletonText }}" loading />
          <view class="banner-meta">
            <t-skeleton
              theme="text"
              rows="{{ [{ width: '120rpx', height: '20rpx' }] }}"
              loading
            />
          </view>
        </view>
      </view>
    </view>

    <view class="banner-list" wx:if="{{ !isLoading }}">
      <view class="banner-item" wx:for="{{ banners }}" wx:key="_id">
        <view class="banner-image-wrap">
          <image
            wx:if="{{ item._hasImage }}"
            src="{{ item.imageUrl }}"
            mode="aspectFill"
            class="banner-img"
            binderror="onImageError"
            data-index="{{ index }}"
          />
          <view wx:else class="banner-img placeholder">
            <t-icon name="image" size="64rpx" color="#cbd5e1" />
            <text class="placeholder-text">无图</text>
          </view>
          <t-tag
            wx:if="{{ item.isSystem }}"
            theme="warning"
            variant="light"
            size="small"
            class="system-tag"
          >系统</t-tag>
          <t-tag
            wx:if="{{ !item._hasTitle }}"
            theme="danger"
            variant="light"
            size="small"
            class="dirty-tag"
          >数据异常</t-tag>
        </view>

        <view class="banner-info">
          <view class="banner-title-row">
            <text class="banner-title">{{ item.title || "未命名" }}</text>
            <t-tag
              theme="{{ item.isActive ? 'success' : 'default' }}"
              variant="light"
              size="small"
            >{{ item.isActive ? "已启用" : "已隐藏" }}</t-tag>
          </view>
          <text class="banner-content-preview">{{
            item.content || "暂无资讯内容"
          }}</text>
          <view class="banner-meta">
            <text class="order-text">排序：{{
              item.order || item.order === 0 ? item.order : "未设置"
            }}</text>
          </view>
        </view>

        <view class="banner-actions">
          <t-button
            variant="text"
            theme="{{ item.isActive ? 'default' : 'primary' }}"
            icon="{{ item.isActive ? 'browse-off' : 'browse' }}"
            bindtap="handleToggleStatus"
            data-banner="{{ item }}"
            t-class="banner-action-btn {{
              item.isSystem ? 'btn-disabled' : ''
            }}"
          />
          <t-button
            variant="text"
            theme="primary"
            icon="edit"
            bindtap="handleEdit"
            data-banner="{{ item }}"
            t-class="banner-action-btn {{
              item.isSystem ? 'btn-disabled' : ''
            }}"
          />
          <t-button
            variant="text"
            theme="danger"
            icon="delete"
            bindtap="handleDelete"
            data-banner="{{ item }}"
            t-class="banner-action-btn {{
              item.isSystem ? 'btn-disabled' : ''
            }}"
          />
        </view>
      </view>
    </view>
  </list-view>
</view>

<t-dialog id="t-dialog" />
<t-toast id="t-toast" />
